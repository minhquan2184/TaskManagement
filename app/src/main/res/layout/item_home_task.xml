<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp">

    <!-- Checkbox circle (unchecked) -->
    <View
        android:id="@+id/checkboxCircle"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:background="@drawable/bg_checkbox_circle" />

    <!-- Checkbox circle (checked / done) -->
    <ImageView
        android:id="@+id/checkboxCircleDone"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:contentDescription="Done"
        android:src="@drawable/ic_check_circle"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Priority dot -->
    <View
        android:id="@+id/priorityDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_priority_dot" />
</LinearLayout>
